# ──────────────────────────────────────────────────────────────
# .env.example — 새 PC 셋업 시 이 파일을 복사해서 .env로 사용
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=brain_tumor
POSTGRES_USER=btuser
POSTGRES_PASSWORD=btpass

# ── LLM Backend ────────────────────────────────────────────────
# "ollama" (로컬) 또는 "groq" (클라우드) 중 선택
LLM_BACKEND=ollama

# Ollama 사용 시 (Docker 컨테이너 → 호스트 Ollama 접근)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma2:2b

# Groq 사용 시 — LLM_BACKEND=groq 로 변경 후 키 입력
GROQ_API_KEY=

# ── 경로 (Docker 컨테이너 내부 경로, 변경 불필요) ─────────────
ML_PIPELINE_PATH=/ml_pipeline
UPLOAD_DIR=/app/uploads
CHROMA_DIR=/app/chroma_db

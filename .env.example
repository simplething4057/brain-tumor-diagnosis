# ── .env.example ──────────────────────────────────
# 이 파일을 복사하여 .env.dev 또는 .env.prod 를 만드세요
# cp .env.example .env.dev

# DB
DATABASE_URL=postgresql://user:password@host:5432/brain_tumor

# LLM
# 개발: local (Ollama 사용)
# 배포: api   (Groq API 사용)
LLM_MODE=local or api

OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3:8b

GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama3-70b-8192

# HuggingFace (모델 가중치 저장소)
# 예: username/brain-tumor-models
HF_REPO_ID=your-username/brain-tumor-models

# 서버
DEBUG=True or False
SECRET_KEY=your-secret-key
